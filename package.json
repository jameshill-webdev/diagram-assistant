{
  "name": "diagram-assistant",
  "version": "1.0.0",
  "description": "LLM-driven diagram and flowchart creation tool",
  "homepage": "https://github.com/jameshill-webdev/diagram-assistant#readme",
  "bugs": {
    "url": "https://github.com/jameshill-webdev/diagram-assistant/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jameshill-webdev/diagram-assistant.git"
  },
  "license": "ISC",
  "author": "James Hill",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n ui,api -c blue,green \"npm run dev -w @diagram-assistant/ui\" \"npm run dev -w @diagram-assistant/api\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.8.1"
  }
}
